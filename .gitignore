# ---- Secrets / credentials ----
# local HuggingFace token (HF_TOKEN); .env.example stays tracked
.env
credentials.env

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.python-version

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- Project outputs ----
# CLI output folders (generated.png, cross_attention.png, ...)
runs/
*.png
*.jpg
*.jpeg
# keep any committed static assets
!webapp/static/**

# ---- Model weights / caches ----
# weights are downloaded at runtime, never commit them
*.safetensors
*.ckpt
*.bin
*.pt
*.pth
.cache/
hf_cache/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
